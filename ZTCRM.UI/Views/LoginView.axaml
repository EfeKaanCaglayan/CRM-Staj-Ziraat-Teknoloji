<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZTCRM.ViewModels"
        x:Class="ZTCRM.UI.Views.LoginView"
        x:DataType="vm:LoginViewModel"
        Title="ZTCRM"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        CanResize="true"
        Background="#2C2C2C"
        Icon="/Assets/Logo2.png">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <DockPanel>

        <!-- HEADER -->
        <Border DockPanel.Dock="Top" Background="#2C2C2C" Height="68" ZIndex="10">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center">
                    <Image Source="/Assets/Logo2.png" Width="52" Height="52"/>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="ZTCRM"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Medium"
                                   LetterSpacing="3"/>
                        <TextBlock Text="ŞİKAYET YÖNETİM SİSTEMİ"
                                   Foreground="#AAAAAA"
                                   FontSize="9"
                                   LetterSpacing="2"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Kurumsal Erişim Portalı"
                               Foreground="#555555" FontSize="11"/>
                    <TextBlock Text="|" Foreground="#3A3A3A" FontSize="11"/>
                    <TextBlock Text="v1.0.0"
                               Foreground="#444444" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Kırmızı çizgi -->
        <Border DockPanel.Dock="Top" Height="3" Background="#E8182E"/>
        <Border DockPanel.Dock="Top" Height="1" Background="#3A3A3A"/>

        <!-- FOOTER -->
        <Border DockPanel.Dock="Bottom" Background="#2C2C2C" Height="44"
                BorderThickness="0,1,0,0" BorderBrush="#3A3A3A">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
                <TextBlock Grid.Column="0"
                           Text="Güvenli bağlantı aktif"
                           Foreground="#444444" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="© 2026 ZTCRM — Şikayet Yönetim Sistemi"
                           Foreground="#333333" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ORTA -->
        <Grid>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#C8102E" Offset="0"/>
                        <GradientStop Color="#8C0B1F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Canvas>
                <Ellipse Canvas.Left="340" Canvas.Top="-140"
                         Width="560" Height="560"
                         Fill="#A50E26" Opacity="0.6"/>
                <Ellipse Canvas.Left="480" Canvas.Top="-60"
                         Width="360" Height="360"
                         Fill="#8C0B1F" Opacity="0.5"/>
                <Ellipse Canvas.Left="-160" Canvas.Top="260"
                         Width="480" Height="480"
                         Fill="#A50E26" Opacity="0.5"/>
            </Canvas>

            <!-- Login kartı -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="380" Background="White" CornerRadius="12"
                    Padding="36,32">
                <Border.BoxShadow>0 8 40 0 #40000000</Border.BoxShadow>

                <StackPanel Spacing="0">

                    <!-- Kart başlık -->
                    <Border BorderThickness="0,0,0,2" BorderBrush="#E8182E"
                            Padding="0,0,0,20" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="40" Height="40" CornerRadius="8"
                                    Background="#E8182E">
                                <PathIcon Width="18" Height="18" Foreground="White"
                                          Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="Sisteme Giriş"
                                           FontSize="15" FontWeight="Medium"
                                           Foreground="#111111"/>
                                <TextBlock Text="Yetkili personel girişi"
                                           FontSize="12" Foreground="#999999"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Rol seçimi -->
                    <Border CornerRadius="8" Background="#F4F4F4"
                            Margin="0,0,0,16" Padding="3">
                        <Grid ColumnDefinitions="*,*">
                            <Button Grid.Column="0" Content="Personel"
                                    Command="{Binding SelectPersonelCommand}"
                                    Classes.active="{Binding IsPersonelTab}"
                                    Classes.inactive="{Binding IsMusteriTab}"
                                    CornerRadius="6" Margin="0,0,3,0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    FontSize="12" Height="34"/>
                            <Button Grid.Column="1" Content="Müşteri"
                                    Command="{Binding SelectMusteriCommand}"
                                    Classes.active="{Binding IsMusteriTab}"
                                    Classes.inactive="{Binding IsPersonelTab}"
                                    CornerRadius="6" Margin="3,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    FontSize="12" Height="34"/>
                        </Grid>
                    </Border>

                    <!-- Kullanıcı adı — sadece Personel tabında -->
                    <TextBox PlaceholderText="Kullanıcı adınızı girin"
                             Text="{Binding Username}"
                             IsVisible="{Binding IsPersonelTab}"
                             Margin="0,0,0,12"
                             Height="38" FontSize="13"
                             Background="#F8F8F8" Foreground="#111111"
                             BorderBrush="#DDDDDD" BorderThickness="1"
                             CornerRadius="6" Padding="10,0"
                             VerticalContentAlignment="Center"/>

                    <!-- TC Kimlik No — sadece Müşteri tabında -->
                    <TextBox x:Name="TcknBox"
                             PlaceholderText="TC Kimlik numaranızı girin"
                             Text="{Binding Username}"
                             IsVisible="{Binding IsTcknVisible}"
                             Margin="0,0,0,8"
                             Height="38" FontSize="13"
                             Background="#F8F8F8" Foreground="#111111"
                             BorderBrush="#DDDDDD" BorderThickness="1"
                             CornerRadius="6" Padding="10,0"
                             VerticalContentAlignment="Center"/>

                    <!-- Yabancı uyruklu checkbox — sadece Müşteri tabında -->
                    <CheckBox Content="Yabancı Uyruklu"
                              IsChecked="{Binding IsYabanciMusteri}"
                              IsVisible="{Binding IsMusteriTab}"
                              Foreground="#444444" FontSize="12"
                              Margin="0,0,0,8"/>

                    <!-- Pasaport No — sadece yabancı müşteride -->
                    <TextBox PlaceholderText="Pasaport numaranızı girin"
                             Text="{Binding Username}"
                             IsVisible="{Binding IsYabanciMusteri}"
                             Margin="0,0,0,12"
                             Height="38" FontSize="13"
                             Background="#F8F8F8" Foreground="#111111"
                             BorderBrush="#DDDDDD" BorderThickness="1"
                             CornerRadius="6" Padding="10,0"
                             VerticalContentAlignment="Center"/>

                    <!-- Şifre — sadece Personel tabında -->
                    <TextBox PlaceholderText="Şifrenizi girin"
                             Text="{Binding Password}"
                             IsVisible="{Binding IsPersonelTab}"
                             PasswordChar="•"
                             Margin="0,0,0,4"
                             Height="38" FontSize="13"
                             Background="#F8F8F8" Foreground="#111111"
                             BorderBrush="#DDDDDD" BorderThickness="1"
                             CornerRadius="6" Padding="10,0"
                             VerticalContentAlignment="Center"/>

                    <!-- Şifremi unuttum — sadece Personel tabında -->
                    <TextBlock Text="Şifremi unuttum"
                               IsVisible="{Binding IsPersonelTab}"
                               Foreground="#E8182E" FontSize="12"
                               HorizontalAlignment="Right"
                               Cursor="Hand" Margin="0,0,0,12"/>

                    <!-- Hata mesajı -->
                    <Border Background="#FEF2F2" BorderBrush="#FECACA"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,10" Margin="0,0,0,12"
                            IsVisible="{Binding ErrorMessage,
                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#B91C1C" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>
                  <!-- Giriş butonu -->
                    <Button Content="Giriş Yap"
                            Command="{Binding LoginCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="46" FontSize="14" FontWeight="Medium"
                            Background="#E8182E" Foreground="White"
                            CornerRadius="8"/>
                    <!-- KVKK checkbox — sadece Müşteri tabında -->
                    <StackPanel Orientation="Vertical" Spacing="4" Margin="0,0,0,12"
                                IsVisible="{Binding IsMusteriTab}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding IsKvkkAccepted}"
                                      VerticalAlignment="Center"/>
                            <TextBlock FontSize="11" Foreground="#555555"
                                       VerticalAlignment="Center"
                                       Text="Kişisel verilerimin işlenmesine ilişkin"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="28,0,0,0">
                            <TextBlock FontSize="11" Foreground="#E8182E"
                                       Text="KVKK Aydınlatma Metni'ni"
                                       TextDecorations="Underline"
                                       Cursor="Hand"
                                       PointerPressed="KvkkText_Click"/>
                            <TextBlock FontSize="11" Foreground="#555555"
                                       Text="okudum ve kabul ediyorum."/>
                        </StackPanel>
                    </StackPanel>

                    <!-- reCAPTCHA badge -->
                    <Border Background="#F8F8F8" CornerRadius="6" Padding="8,6"
                            Margin="0,10,0,0" IsVisible="{Binding IsMusteriTab}">
                        <StackPanel Orientation="Horizontal" Spacing="6"
                                    HorizontalAlignment="Center">
                            <PathIcon Width="12" Height="12" Foreground="#E8182E"
                                      Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
                            <TextBlock Text="Bu site reCAPTCHA v3 ile korunmaktadır"
                                       FontSize="10" Foreground="#777777"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>

    </DockPanel>
</Window>