<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZTCRM.ViewModels"
        xmlns:models="using:ZTCRM.Models"
        xmlns:views="using:ZTCRM.UI.Views"
        x:Class="ZTCRM.UI.Views.AdminView"
        x:DataType="vm:AdminViewModel"
        Title="ZTCRM — Admin Paneli"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Background="#2C2C2C"
        Icon="/Assets/Logo2.png">

    <DockPanel>

        <!-- HEADER -->
        <Border DockPanel.Dock="Top" Background="#2C2C2C" Height="68" ZIndex="10">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center">
                    <Image Source="/Assets/Logo2.png" Width="52" Height="52"/>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="ZTCRM" Foreground="White" FontSize="18"
                                   FontWeight="Medium" LetterSpacing="3"/>
                        <TextBlock Text="ŞİKAYET YÖNETİM SİSTEMİ"
                                   Foreground="#AAAAAA" FontSize="9" LetterSpacing="2"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{Binding WelcomeMessage}"
                               Foreground="#AAAAAA" FontSize="12"/>
                    <TextBlock Text="|" Foreground="#3A3A3A" FontSize="11"/>
                    <TextBlock Text="v1.0.0" Foreground="#444444" FontSize="11"/>
                    <TextBlock Text="|" Foreground="#3A3A3A" FontSize="11"/>
                    <Button Content="Çıkış Yap"
                            Click="LogoutButton_Click"
                            Background="Transparent"
                            Foreground="#AAAAAA"
                            FontSize="12"
                            Padding="8,4"
                            CornerRadius="6"
                            VerticalAlignment="Center"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Kırmızı çizgi -->
        <Border DockPanel.Dock="Top" Height="3" Background="#E8182E"/>
        <Border DockPanel.Dock="Top" Height="1" Background="#3A3A3A"/>

        <!-- FOOTER -->
        <Border DockPanel.Dock="Bottom" Background="#2C2C2C" Height="44"
                BorderThickness="0,1,0,0" BorderBrush="#3A3A3A">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
                <TextBlock Grid.Column="0" Text="Güvenli bağlantı aktif"
                           Foreground="#444444" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="© 2026 ZTCRM — Şikayet Yönetim Sistemi"
                           Foreground="#333333" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ORTA -->
        <Grid>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#C8102E" Offset="0"/>
                        <GradientStop Color="#8C0B1F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Canvas>
                <Ellipse Canvas.Left="700" Canvas.Top="-140"
                         Width="560" Height="560"
                         Fill="#A50E26" Opacity="0.5"/>
                <Ellipse Canvas.Left="-160" Canvas.Top="300"
                         Width="480" Height="480"
                         Fill="#A50E26" Opacity="0.4"/>
            </Canvas>

            <Border Margin="32" Background="White" CornerRadius="12" Padding="28,24">
                <Border.BoxShadow>0 8 40 0 #40000000</Border.BoxShadow>

                <TabControl>
                    <!-- DASHBOARD SEKMESI -->
                    <TabItem Header="Dashboard">
                        <views:DashboardView Margin="0,16,0,0"/>
                    </TabItem>

                    <!-- BİRİMLER SEKMESI -->
                    <TabItem Header="Birimler">
                        <Grid ColumnDefinitions="*,380" Margin="0,16,0,0">

                            <Border Grid.Column="0" Margin="0,0,16,0">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,12">
                                        <TextBlock Grid.Column="0"
                                                   Text="Mevcut Birimler"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="#111111"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding UnitsSearchText}"
                                                 PlaceholderText="Ara..."
                                                 Height="36" Width="180" FontSize="12"
                                                 Background="#F8F8F8" Foreground="#111111"
                                                 BorderBrush="#DDDDDD" BorderThickness="1"
                                                 CornerRadius="6" Padding="10,0"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"/>
                                        <ToggleButton Grid.Column="2"
                                                      IsChecked="{Binding ShowOnlyActiveUnits, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Padding="10,6"
                                                      CornerRadius="6"
                                                      FontSize="11"
                                                      Margin="0,0,8,0">
                                            <ToggleButton.Styles>
                                                <Style Selector="ToggleButton">
                                                    <Setter Property="Background" Value="#F5F5F5"/>
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                    <Setter Property="Content" Value="Tümünü Göster"/>
                                                </Style>
                                                <Style Selector="ToggleButton:checked">
                                                    <Setter Property="Background" Value="#E8182E"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Content" Value="Sadece Aktif"/>
                                                </Style>
                                            </ToggleButton.Styles>
                                        </ToggleButton>
                                        <Button Grid.Column="3"
                                                Command="{Binding RefreshCommand}"
                                                Width="36" Height="36"
                                                CornerRadius="8"
                                                Background="#F5F5F5"
                                                VerticalAlignment="Center"
                                                ToolTip.Tip="Yenile">
                                            <Panel>
                                                <PathIcon Width="16" Height="16" Foreground="#555555"
                                                          IsVisible="{Binding !IsRefreshing}"
                                                          Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/>
                                                <PathIcon Width="16" Height="16" Foreground="#E8182E"
                                                          IsVisible="{Binding IsRefreshing}"
                                                          Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z">
                                                    <PathIcon.Styles>
                                                        <Style Selector="PathIcon">
                                                            <Style.Animations>
                                                                <Animation Duration="0:0:1" IterationCount="Infinite">
                                                                    <KeyFrame Cue="0%">
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </KeyFrame>
                                                                    <KeyFrame Cue="50%">
                                                                        <Setter Property="Opacity" Value="0.2"/>
                                                                    </KeyFrame>
                                                                    <KeyFrame Cue="100%">
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </KeyFrame>
                                                                </Animation>
                                                            </Style.Animations>
                                                        </Style>
                                                    </PathIcon.Styles>
                                                </PathIcon>
                                            </Panel>
                                        </Button>
                                    </Grid>
                                    <DataGrid Sorting="UnitsGrid_Sorting"
                                              ItemsSource="{Binding FilteredUnits}"
                                              SelectedItem="{Binding SelectedUnit}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserSortColumns="True"
                                              CanUserReorderColumns="False"
                                              GridLinesVisibility="Horizontal"
                                              BorderThickness="1"
                                              BorderBrush="#EEEEEE">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID"
                                                                Binding="{Binding UnitId}"
                                                                Width="55"
                                                                CanUserSort="True"/>
                                            <DataGridTextColumn Header="Birim Adı"
                                                                Binding="{Binding UnitName}"
                                                                Width="*"
                                                                CanUserSort="True"/>
                                            <DataGridTextColumn Header="Tip"
                                                                Binding="{Binding UnitType}"
                                                                Width="110"
                                                                CanUserSort="True"/>
                                            <DataGridTextColumn Header="Aktif"
                                                                Binding="{Binding IsActiveText}"
                                                                Width="70"
                                                                CanUserSort="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#F8F8F8"
                                    CornerRadius="8" Padding="20">
                                <StackPanel Spacing="0">
                                    <TextBlock Text="YENİ BİRİM EKLE"
                                               FontSize="10" Foreground="#999999"
                                               LetterSpacing="1" Margin="0,0,0,16"/>
                                    <TextBlock Text="Birim Adı" FontSize="12"
                                               Foreground="#555555" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewUnitName}"
                                             PlaceholderText="Birim adını girin"
                                             Height="38" FontSize="13"
                                             Background="White" Foreground="#111111"
                                             BorderBrush="#DDDDDD" BorderThickness="1"
                                             CornerRadius="6" Padding="10,0"
                                             Margin="0,0,0,12"/>
                                    <TextBlock Text="Birim Tipi" FontSize="12"
                                               Foreground="#555555" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding UnitTypes}"
                                              SelectedItem="{Binding NewUnitType}"
                                              PlaceholderText="Tip seçin"
                                              HorizontalAlignment="Stretch"
                                              Height="38" FontSize="13"
                                              Margin="0,0,0,16"/>
                                    <Button Content="Birim Ekle"
                                            Command="{Binding CreateUnitCommand}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Height="42" FontSize="13" FontWeight="Medium"
                                            Background="#E8182E" Foreground="White"
                                            CornerRadius="8" Margin="0,0,0,8"/>
                                    <Border Height="1" Background="#EEEEEE" Margin="0,8,0,16"/>
                                    <TextBlock Text="SEÇİLİ BİRİM"
                                               FontSize="10" Foreground="#999999"
                                               LetterSpacing="1" Margin="0,0,0,12"/>
                                    <Border Background="White" CornerRadius="8"
                                            Padding="14,10" Margin="0,0,0,12"
                                            IsVisible="{Binding SelectedUnit,
                                                        Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding SelectedUnit.UnitName}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="#111111"/>
                                            <TextBlock Text="{Binding SelectedUnit.UnitType}"
                                                       FontSize="12" Foreground="#555555"/>
                                        </StackPanel>
                                    </Border>
                                    <Button Content="Birimi Pasife Al"
                                            Command="{Binding DeactivateUnitCommand}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Height="42" FontSize="13" FontWeight="Medium"
                                            Background="#555555" Foreground="White"
                                            CornerRadius="8"/>
                                    <Border Background="#FEF2F2" BorderBrush="#FECACA"
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="12,10" Margin="0,12,0,0"
                                            IsVisible="{Binding ErrorMessage,
                                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Text="{Binding ErrorMessage}"
                                                   Foreground="#B91C1C" FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                    <Border Background="#F0FDF4" BorderBrush="#BBF7D0"
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="12,10" Margin="0,8,0,0"
                                            IsVisible="{Binding SuccessMessage,
                                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Text="{Binding SuccessMessage}"
                                                   Foreground="#15803D" FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </TabItem>

                    <!-- PERSONEL SEKMESI -->
                    <TabItem Header="Personel">
                        <Grid ColumnDefinitions="*,400" Margin="0,16,0,0">

                            <Border Grid.Column="0" Margin="0,0,16,0">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,12">
                                        <TextBlock Grid.Column="0"
                                                   Text="Mevcut Personel"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="#111111"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding StaffSearchText}"
                                                 PlaceholderText="Ara..."
                                                 Height="36" Width="180" FontSize="12"
                                                 Background="#F8F8F8" Foreground="#111111"
                                                 BorderBrush="#DDDDDD" BorderThickness="1"
                                                 CornerRadius="6" Padding="10,0"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"/>
                                        <ToggleButton Grid.Column="2"
                                                      IsChecked="{Binding ShowOnlyActiveStaff, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Padding="10,6"
                                                      CornerRadius="6"
                                                      FontSize="11"
                                                      Margin="0,0,8,0">
                                            <ToggleButton.Styles>
                                                <Style Selector="ToggleButton">
                                                    <Setter Property="Background" Value="#F5F5F5"/>
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                    <Setter Property="Content" Value="Tümünü Göster"/>
                                                </Style>
                                                <Style Selector="ToggleButton:checked">
                                                    <Setter Property="Background" Value="#E8182E"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Content" Value="Sadece Aktif"/>
                                                </Style>
                                            </ToggleButton.Styles>
                                        </ToggleButton>
                                        <Button Grid.Column="3"
                                                Command="{Binding RefreshCommand}"
                                                Width="36" Height="36"
                                                CornerRadius="8"
                                                Background="#F5F5F5"
                                                VerticalAlignment="Center"
                                                ToolTip.Tip="Yenile">
                                            <Panel>
                                                <PathIcon Width="16" Height="16" Foreground="#555555"
                                                          IsVisible="{Binding !IsRefreshing}"
                                                          Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/>
                                                <PathIcon Width="16" Height="16" Foreground="#E8182E"
                                                          IsVisible="{Binding IsRefreshing}"
                                                          Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z">
                                                    <PathIcon.Styles>
                                                        <Style Selector="PathIcon">
                                                            <Style.Animations>
                                                                <Animation Duration="0:0:1" IterationCount="Infinite">
                                                                    <KeyFrame Cue="0%">
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </KeyFrame>
                                                                    <KeyFrame Cue="50%">
                                                                        <Setter Property="Opacity" Value="0.2"/>
                                                                    </KeyFrame>
                                                                    <KeyFrame Cue="100%">
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </KeyFrame>
                                                                </Animation>
                                                            </Style.Animations>
                                                        </Style>
                                                    </PathIcon.Styles>
                                                </PathIcon>
                                            </Panel>
                                        </Button>
                                    </Grid>
                                    <DataGrid Sorting="StaffGrid_Sorting"
                                              ItemsSource="{Binding FilteredStaffList}"
                                              SelectedItem="{Binding SelectedStaff}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserSortColumns="True"
                                              CanUserReorderColumns="False"
                                              GridLinesVisibility="Horizontal"
                                              BorderThickness="1"
                                              BorderBrush="#EEEEEE">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID"
                                                                Binding="{Binding StaffId}"
                                                                Width="55"
                                                                CanUserSort="True"/>
                                            <DataGridTextColumn Header="Ad Soyad"
                                                                Binding="{Binding FullName}"
                                                                Width="*"
                                                                CanUserSort="True"/>
                                            <DataGridTextColumn Header="Kullanıcı Adı"
                                                                Binding="{Binding Username}"
                                                                Width="150"
                                                                CanUserSort="True"/>
                                            <DataGridTextColumn Header="Rol"
                                                                Binding="{Binding RoleName}"
                                                                Width="70"
                                                                CanUserSort="True"/>
                                            <DataGridTextColumn Header="Birim"
                                                                Binding="{Binding UnitName}"
                                                                Width="*"
                                                                CanUserSort="True"/>
                                            <DataGridTextColumn Header="Personel Aktif"
                                                                Binding="{Binding IsActiveText}"
                                                                Width="70"
                                                                CanUserSort="True"/>
                                            <DataGridTextColumn Header="Birim Aktif"
                                                                Binding="{Binding UnitIsActiveText}"
                                                                Width="90"
                                                                CanUserSort="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                    <Border Grid.Column="1" Background="#F8F8F8" CornerRadius="8" Padding="0">
    <TabControl>
        
        <!-- TAB 1: Personel Ekle -->
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0">
                    <PathIcon Width="13" Height="13"
                              Data="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    <TextBlock Text="Personel Ekle" FontSize="12"/>
                </StackPanel>
            </TabItem.Header>
            <ScrollViewer>
                <StackPanel Spacing="0" Margin="20">
                    <TextBlock Text="YENİ PERSONEL EKLE"
                               FontSize="10" Foreground="#999999"
                               LetterSpacing="1" Margin="0,0,0,16"/>
                    <TextBlock Text="Ad Soyad" FontSize="12"
                               Foreground="#555555" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NewFullName}"
                             PlaceholderText="Ad soyad girin"
                             Height="38" FontSize="13"
                             Background="White" Foreground="#111111"
                             BorderBrush="#DDDDDD" BorderThickness="1"
                             CornerRadius="6" Padding="10,0"
                             Margin="0,0,0,12"/>
                    <TextBlock Text="Kullanıcı Adı" FontSize="12"
                               Foreground="#555555" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NewUsername}"
                             PlaceholderText="Kullanıcı adı girin"
                             Height="38" FontSize="13"
                             Background="White" Foreground="#111111"
                             BorderBrush="#DDDDDD" BorderThickness="1"
                             CornerRadius="6" Padding="10,0"
                             Margin="0,0,0,12"/>
                    <TextBlock Text="Şifre" FontSize="12"
                               Foreground="#555555" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NewPasswordHash}"
                             PlaceholderText="Şifre girin"
                             PasswordChar="•"
                             Height="38" FontSize="13"
                             Background="White" Foreground="#111111"
                             BorderBrush="#DDDDDD" BorderThickness="1"
                             CornerRadius="6" Padding="10,0"
                             Margin="0,0,0,12"/>
                    <TextBlock Text="Rol" FontSize="12"
                               Foreground="#555555" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding RoleNames}"
                              SelectedItem="{Binding NewRoleName}"
                              HorizontalAlignment="Stretch"
                              Height="38" FontSize="13"
                              Margin="0,0,0,16"/>
                    <Button Content="Personel Ekle"
                            Command="{Binding CreateStaffCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="42" FontSize="13" FontWeight="Medium"
                            Background="#E8182E" Foreground="White"
                            CornerRadius="8"/>

                    <Border Background="#FEF2F2" BorderBrush="#FECACA"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,10" Margin="0,12,0,0"
                            IsVisible="{Binding ErrorMessage,
                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#B91C1C" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>
                    <Border Background="#F0FDF4" BorderBrush="#BBF7D0"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,10" Margin="0,8,0,0"
                            IsVisible="{Binding SuccessMessage,
                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding SuccessMessage}"
                                   Foreground="#15803D" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- TAB 2: Rol Güncelle / Birim Ata -->
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0">
                    <PathIcon Width="13" Height="13"
                              Data="M12 4c-4.42 0-8 3.58-8 8s3.58 8 8 8 8-3.58 8-8-3.58-8-8-8zm1 13h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                    <TextBlock Text="Rol &amp; Birim" FontSize="12"/>
                </StackPanel>
            </TabItem.Header>
            <ScrollViewer>
                <StackPanel Spacing="0" Margin="20">
                    <TextBlock Text="ROL GÜNCELLE"
                               FontSize="10" Foreground="#999999"
                               LetterSpacing="1" Margin="0,0,0,12"/>
                    <Border Background="White" CornerRadius="8"
                            Padding="14,10" Margin="0,0,0,12"
                            IsVisible="{Binding SelectedStaff,
                                        Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding SelectedStaff.FullName}"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="#111111"/>
                            <TextBlock Text="{Binding SelectedStaff.RoleName, StringFormat='Mevcut Rol: {0}'}"
                                       FontSize="12" Foreground="#555555"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Yeni Rol" FontSize="12"
                               Foreground="#555555" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding RoleNames}"
                              SelectedItem="{Binding UpdateRoleName}"
                              PlaceholderText="Rol seçin"
                              HorizontalAlignment="Stretch"
                              Height="38" FontSize="13"
                              Margin="0,0,0,16"/>
                    <Button Content="Rolü Güncelle"
                            Command="{Binding UpdateStaffRoleCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="42" FontSize="13" FontWeight="Medium"
                            Background="#555555" Foreground="White"
                            CornerRadius="8" Margin="0,0,0,16"/>

                    <Border Height="1" Background="#EEEEEE" Margin="0,0,0,16"/>

                    <TextBlock Text="BİRİM ATA"
                               FontSize="10" Foreground="#999999"
                               LetterSpacing="1" Margin="0,0,0,12"/>
                    <TextBlock Text="Birim Seç" FontSize="12"
                               Foreground="#555555" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Units}"
                              SelectedItem="{Binding SelectedUnitForStaff}"
                              PlaceholderText="Birim seçin"
                              HorizontalAlignment="Stretch"
                              Height="38" FontSize="13"
                              Margin="0,0,0,16">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:OrgUnit">
                                <TextBlock Text="{Binding UnitName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Birime Ata"
                            Command="{Binding AssignStaffToUnitCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="42" FontSize="13" FontWeight="Medium"
                            Background="#0369A1" Foreground="White"
                            CornerRadius="8"/>

                    <Border Background="#FEF2F2" BorderBrush="#FECACA"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,10" Margin="0,12,0,0"
                            IsVisible="{Binding ErrorMessage,
                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#B91C1C" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>
                    <Border Background="#F0FDF4" BorderBrush="#BBF7D0"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,10" Margin="0,8,0,0"
                            IsVisible="{Binding SuccessMessage,
                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding SuccessMessage}"
                                   Foreground="#15803D" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

              </TabControl>
           </Border>
        </Grid>
                    </TabItem>

                  <!-- AKTİVİTE LOGU SEKMESI -->
                    <TabItem Header="Aktivite Logu">
                        <DockPanel Margin="0,16,0,0">
                            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,12">
                                <TextBlock Grid.Column="0"
                                           Text="Sistem Aktivite Logu"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="#111111"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding LogSearchText}"
                                         PlaceholderText="Ara..."
                                         Height="36" Width="220" FontSize="12"
                                         Background="#F8F8F8" Foreground="#111111"
                                         BorderBrush="#DDDDDD" BorderThickness="1"
                                         CornerRadius="6" Padding="10,0"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center"/>
                                <Button Grid.Column="2"
                                        Click="ExportActivityLogButton_Click"
                                        Width="36" Height="36"
                                        CornerRadius="8"
                                        Background="#0369A1"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Excel'e Aktar">
                                    <PathIcon Width="16" Height="16" Foreground="White"
                                              Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
                                </Button>
                                <Button Grid.Column="3"
                                        Command="{Binding RefreshCommand}"
                                        Width="36" Height="36"
                                        CornerRadius="8"
                                        Background="#F5F5F5"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Yenile">
                                    <Panel>
                                        <PathIcon Width="16" Height="16" Foreground="#555555"
                                                  IsVisible="{Binding !IsRefreshing}"
                                                  Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/>
                                        <PathIcon Width="16" Height="16" Foreground="#E8182E"
                                                  IsVisible="{Binding IsRefreshing}"
                                                  Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z">
                                            <PathIcon.Styles>
                                                <Style Selector="PathIcon">
                                                    <Style.Animations>
                                                        <Animation Duration="0:0:1" IterationCount="Infinite">
                                                            <KeyFrame Cue="0%">
                                                                <Setter Property="Opacity" Value="1"/>
                                                            </KeyFrame>
                                                            <KeyFrame Cue="50%">
                                                                <Setter Property="Opacity" Value="0.2"/>
                                                            </KeyFrame>
                                                            <KeyFrame Cue="100%">
                                                                <Setter Property="Opacity" Value="1"/>
                                                            </KeyFrame>
                                                        </Animation>
                                                    </Style.Animations>
                                                </Style>
                                            </PathIcon.Styles>
                                        </PathIcon>
                                    </Panel>
                                </Button>
                            </Grid>
                            <DataGrid Sorting="ActivityGrid_Sorting"
                                      ItemsSource="{Binding FilteredActivityLogs}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserSortColumns="True"
                                      CanUserReorderColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="1"
                                      BorderBrush="#EEEEEE">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Log ID"
                                                        Binding="{Binding LogId}"
                                                        Width="70"
                                                        CanUserSort="True"/>
                                    <DataGridTextColumn Header="Başvuru No"
                                                        Binding="{Binding RequestId}"
                                                        Width="90"
                                                        CanUserSort="True"/>
                                    <DataGridTextColumn Header="Eski Durum"
                                                        Binding="{Binding OldStatus}"
                                                        Width="150"
                                                        CanUserSort="True"/>
                                    <DataGridTextColumn Header="Yeni Durum"
                                                        Binding="{Binding NewStatus}"
                                                        Width="150"
                                                        CanUserSort="True"/>
                                    <DataGridTextColumn Header="Değiştiren"
                                                        Binding="{Binding ChangedBy}"
                                                        Width="200"
                                                        CanUserSort="True"/>
                                    <DataGridTextColumn Header="Tarih"
                                                        Binding="{Binding ChangedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                                        Width="*"
                                                        CanUserSort="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </TabItem>

                </TabControl>
            </Border>
        </Grid>

    </DockPanel>
</Window>