<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:ZTCRM.Models"
        x:Class="ZTCRM.UI.Views.NotificationView"
        x:DataType="x:Object"
        Title="Bildirimler"
        Width="500" Height="400"
        WindowStartupLocation="CenterOwner"
        Background="White"
        Icon="/Assets/Logo2.png">

    <Border Padding="24">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Text="Bildirimlerim"
                       FontSize="16" FontWeight="Medium"
                       Foreground="#111111" Margin="0,0,0,16"/>

            <ListBox ItemsSource="{Binding}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Notification">
                        <Border BorderThickness="0,0,0,1" BorderBrush="#EEEEEE" Padding="0,8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Message}"
                                           FontSize="13" Foreground="#111111"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                           FontSize="11" Foreground="#999999"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>