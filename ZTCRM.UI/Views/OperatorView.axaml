<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZTCRM.ViewModels"
        xmlns:models="using:ZTCRM.Models"
        x:Class="ZTCRM.UI.Views.OperatorView"
        x:DataType="vm:OperatorViewModel"
        Title="ZTCRM — Operatör Paneli"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Background="#2C2C2C">

    <DockPanel>

        <!-- HEADER -->
        <Border DockPanel.Dock="Top" Background="#2C2C2C" Height="68" ZIndex="10">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center">
                    <Image Source="/Assets/Logo2.png" Width="42" Height="42"/>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="ZTCRM" Foreground="White" FontSize="18"
                                   FontWeight="Medium" LetterSpacing="3"/>
                        <TextBlock Text="ŞİKAYET YÖNETİM SİSTEMİ"
                                   Foreground="#AAAAAA" FontSize="9" LetterSpacing="2"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{Binding WelcomeMessage}"
                               Foreground="#AAAAAA" FontSize="12"/>
                    <TextBlock Text="|" Foreground="#3A3A3A" FontSize="11"/>
                    <TextBlock Text="v1.0.0" Foreground="#444444" FontSize="11"/>
                    <TextBlock Text="|" Foreground="#3A3A3A" FontSize="11"/>
                    <Button Content="Çıkış Yap"
                            Click="LogoutButton_Click"
                            Background="Transparent"
                            Foreground="#AAAAAA"
                            FontSize="12"
                            Padding="8,4"
                            CornerRadius="6"
                            VerticalAlignment="Center"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Kırmızı çizgi -->
        <Border DockPanel.Dock="Top" Height="3" Background="#E8182E"/>
        <Border DockPanel.Dock="Top" Height="1" Background="#3A3A3A"/>

        <!-- FOOTER -->
        <Border DockPanel.Dock="Bottom" Background="#2C2C2C" Height="44"
                BorderThickness="0,1,0,0" BorderBrush="#3A3A3A">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
                <TextBlock Grid.Column="0" Text="Güvenli bağlantı aktif"
                           Foreground="#444444" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="© 2026 ZTCRM — Şikayet Yönetim Sistemi"
                           Foreground="#333333" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ORTA -->
        <Grid>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#C8102E" Offset="0"/>
                        <GradientStop Color="#8C0B1F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Canvas>
                <Ellipse Canvas.Left="700" Canvas.Top="-140"
                         Width="560" Height="560"
                         Fill="#A50E26" Opacity="0.5"/>
                <Ellipse Canvas.Left="-160" Canvas.Top="300"
                         Width="480" Height="480"
                         Fill="#A50E26" Opacity="0.4"/>
            </Canvas>

            <Grid ColumnDefinitions="*,380" Margin="32">

                <!-- SOL: TabControl -->
                <Border Grid.Column="0" Background="White" CornerRadius="12"
                        Padding="28,24" Margin="0,0,16,0">
                    <Border.BoxShadow>0 8 40 0 #40000000</Border.BoxShadow>
                    <TabControl SelectedIndex="{Binding SelectedTabIndex}">

                        <!-- TAB 1: Bekleyen Başvurular -->
                        <TabItem Header="Bekleyen Başvurular">
                            <DockPanel>
                                <Border DockPanel.Dock="Top"
                                        BorderThickness="0,0,0,2" BorderBrush="#E8182E"
                                        Padding="0,0,0,16" Margin="0,0,0,20">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                            <Border Width="36" Height="36" CornerRadius="8" Background="#E8182E">
                                                <PathIcon Width="16" Height="16" Foreground="White"
                                                          Data="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="Bekleyen Başvurular"
                                                           FontSize="14" FontWeight="Medium"
                                                           Foreground="#111111"/>
                                                <TextBlock Text="Kategorize edilmeyi bekleyen başvurular"
                                                           FontSize="11" Foreground="#999999"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Command="{Binding RefreshCommand}"
                                                Width="36" Height="36"
                                                CornerRadius="8"
                                                Background="#F5F5F5"
                                                VerticalAlignment="Center"
                                                ToolTip.Tip="Yenile">
                                            <Panel>
                                                <PathIcon Width="16" Height="16" Foreground="#555555"
                                                          IsVisible="{Binding !IsRefreshing}"
                                                          Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/>
                                                <PathIcon Width="16" Height="16" Foreground="#E8182E"
                                                          IsVisible="{Binding IsRefreshing}"
                                                          Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z">
                                                    <PathIcon.Styles>
                                                        <Style Selector="PathIcon">
                                                            <Style.Animations>
                                                                <Animation Duration="0:0:1" IterationCount="Infinite">
                                                                    <KeyFrame Cue="0%">
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </KeyFrame>
                                                                    <KeyFrame Cue="50%">
                                                                        <Setter Property="Opacity" Value="0.2"/>
                                                                    </KeyFrame>
                                                                    <KeyFrame Cue="100%">
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </KeyFrame>
                                                                </Animation>
                                                            </Style.Animations>
                                                        </Style>
                                                    </PathIcon.Styles>
                                                </PathIcon>
                                            </Panel>
                                        </Button>
                                    </Grid>
                                </Border>

                                <DataGrid Sorting="RequestsGrid_Sorting"
                                          ItemsSource="{Binding Requests}"
                                          SelectedItem="{Binding SelectedRequest}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="True"
                                          CanUserReorderColumns="False"
                                          GridLinesVisibility="Horizontal"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="No"
                                                            Binding="{Binding RequestId}"
                                                            Width="55"
                                                            CanUserSort="True"/>
                                        <DataGridTextColumn Header="Müşteri"
                                                            Binding="{Binding CustomerName}"
                                                            Width="140"
                                                            CanUserSort="True"/>
                                        <DataGridTextColumn Header="Açıklama"
                                                            Binding="{Binding Description}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="Tarih"
                                                            Binding="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                                            Width="110"
                                                            CanUserSort="True"/>
                                        <DataGridTemplateColumn Header="Detay" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate x:DataType="models:ServiceRequest">
                                                    <Button Content="Detay"
                                                            Tag="{Binding}"
                                                            Click="DetailButton_Click"
                                                            HorizontalAlignment="Center"
                                                            Height="26" FontSize="11"
                                                            Background="#E8182E" Foreground="White"
                                                            CornerRadius="4" Padding="10,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </TabItem>

                        <!-- TAB 2: Havuzdaki Başvurular -->
                        <TabItem Header="Havuzdaki Başvurular">
                            <DockPanel>
                                <Border DockPanel.Dock="Top"
                                        BorderThickness="0,0,0,2" BorderBrush="#E8182E"
                                        Padding="0,0,0,16" Margin="0,0,0,20">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                            <Border Width="36" Height="36" CornerRadius="8" Background="#E8182E">
                                                <PathIcon Width="16" Height="16" Foreground="White"
                                                          Data="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="Havuzdaki Başvurular"
                                                           FontSize="14" FontWeight="Medium"
                                                           Foreground="#111111"/>
                                                <TextBlock Text="Havuzdaki tüm başvurular"
                                                           FontSize="11" Foreground="#999999"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Command="{Binding RefreshCommand}"
                                                Width="36" Height="36"
                                                CornerRadius="8"
                                                Background="#F5F5F5"
                                                VerticalAlignment="Center"
                                                ToolTip.Tip="Yenile">
                                            <Panel>
                                                <PathIcon Width="16" Height="16" Foreground="#555555"
                                                          IsVisible="{Binding !IsRefreshing}"
                                                          Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/>
                                                <PathIcon Width="16" Height="16" Foreground="#E8182E"
                                                          IsVisible="{Binding IsRefreshing}"
                                                          Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z">
                                                    <PathIcon.Styles>
                                                        <Style Selector="PathIcon">
                                                            <Style.Animations>
                                                                <Animation Duration="0:0:1" IterationCount="Infinite">
                                                                    <KeyFrame Cue="0%">
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </KeyFrame>
                                                                    <KeyFrame Cue="50%">
                                                                        <Setter Property="Opacity" Value="0.2"/>
                                                                    </KeyFrame>
                                                                    <KeyFrame Cue="100%">
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </KeyFrame>
                                                                </Animation>
                                                            </Style.Animations>
                                                        </Style>
                                                    </PathIcon.Styles>
                                                </PathIcon>
                                            </Panel>
                                        </Button>
                                    </Grid>
                                </Border>

                                <DataGrid ItemsSource="{Binding PoolRequests}"
                                          SelectedItem="{Binding SelectedPoolRequest}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="True"
                                          CanUserReorderColumns="False"
                                          GridLinesVisibility="Horizontal"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="No"
                                                            Binding="{Binding RequestId}"
                                                            Width="55"/>
                                        <DataGridTextColumn Header="Müşteri"
                                                            Binding="{Binding CustomerName}"
                                                            Width="140"/>
                                        <DataGridTextColumn Header="Kategori"
                                                            Binding="{Binding CategoryName}"
                                                            Width="120"/>
                                        <DataGridTextColumn Header="Öncelik"
                                                            Binding="{Binding Priority}"
                                                            Width="80"/>
                                        <DataGridTextColumn Header="Açıklama"
                                                            Binding="{Binding Description}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="Tarih"
                                                            Binding="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                                            Width="110"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </TabItem>

                    </TabControl>
                </Border>

                <!-- SAĞ: İşlem Paneli -->
                <Border Grid.Column="1" Background="White" CornerRadius="12"
                        Padding="28,24">
                    <Border.BoxShadow>0 8 40 0 #40000000</Border.BoxShadow>
                    <ScrollViewer>
                        <StackPanel Spacing="0">

                            <Border BorderThickness="0,0,0,2" BorderBrush="#E8182E"
                                    Padding="0,0,0,16" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="36" Height="36" CornerRadius="8" Background="#E8182E">
                                        <PathIcon Width="16" Height="16" Foreground="White"
                                                  Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="İşlem Paneli"
                                                   FontSize="14" FontWeight="Medium"
                                                   Foreground="#111111"/>
                                        <TextBlock Text="Seçili başvuruyu yönetin"
                                                   FontSize="11" Foreground="#999999"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- TAB 1 İÇERİĞİ -->
                            <StackPanel IsVisible="{Binding IsTab1Selected}">
                                <Border Background="#F8F8F8" CornerRadius="8"
                                        Padding="14,10" Margin="0,0,0,16"
                                        IsVisible="{Binding SelectedRequest,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="SEÇİLİ BAŞVURU"
                                                   FontSize="10" Foreground="#999999"/>
                                        <TextBlock Text="{Binding SelectedRequest.RequestId, StringFormat='#{0}'}"
                                                   FontSize="13" FontWeight="Medium" Foreground="#E8182E"/>
                                        <TextBlock Text="{Binding SelectedRequest.CustomerName}"
                                                   FontSize="12" Foreground="#555555"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Kategori" FontSize="12"
                                           Foreground="#555555" Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding Categories}"
                                          SelectedItem="{Binding SelectedCategory}"
                                          PlaceholderText="Kategori seçin"
                                          HorizontalAlignment="Stretch"
                                          Height="38" FontSize="13"
                                          Margin="0,0,0,14">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:Category">
                                            <TextBlock Text="{Binding CategoryName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="Öncelik" FontSize="12"
                                           Foreground="#555555" Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding Priorities}"
                                          SelectedItem="{Binding SelectedPriority}"
                                          PlaceholderText="Öncelik seçin"
                                          HorizontalAlignment="Stretch"
                                          Height="38" FontSize="13"
                                          Margin="0,0,0,14"/>

                                <Button Content="Havuza Ekle"
                                        Command="{Binding CategorizeAndPoolCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Height="42" FontSize="13" FontWeight="Medium"
                                        Background="#E8182E" Foreground="White"
                                        CornerRadius="8" Margin="0,0,0,8"/>

                                <Border Height="1" Background="#EEEEEE" Margin="0,0,0,20"/>

                                <TextBlock Text="BAŞVURUYU REDDET"
                                           FontSize="10" Foreground="#999999"
                                           LetterSpacing="1" Margin="0,0,0,12"/>

                                <TextBlock Text="Red Türü" FontSize="12"
                                           Foreground="#555555" Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding RejectionTypes}"
                                          SelectedItem="{Binding SelectedRejectionType}"
                                          PlaceholderText="Red türü seçin"
                                          HorizontalAlignment="Stretch"
                                          Height="38" FontSize="13"
                                          Margin="0,0,0,14"/>

                                <TextBlock Text="Red Sebebi" FontSize="12"
                                           Foreground="#555555" Margin="0,0,0,6"/>
                                <TextBox PlaceholderText="Red sebebini açıklayın..."
                                         Text="{Binding RejectionReason}"
                                         Height="80" FontSize="13"
                                         Background="#F8F8F8" Foreground="#111111"
                                         BorderBrush="#DDDDDD" BorderThickness="1"
                                         CornerRadius="6" Padding="10,8"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         Margin="0,0,0,14"/>

                                <Button Content="Reddet"
                                        Command="{Binding RejectCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Height="42" FontSize="13" FontWeight="Medium"
                                        Background="#555555" Foreground="White"
                                        CornerRadius="8"/>
                            </StackPanel>

                            <!-- TAB 2 İÇERİĞİ -->
                            <StackPanel IsVisible="{Binding IsTab2Selected}">
                                <Border Background="#F8F8F8" CornerRadius="8"
                                        Padding="14,10" Margin="0,0,0,16"
                                        IsVisible="{Binding SelectedPoolRequest,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="SEÇİLİ BAŞVURU"
                                                   FontSize="10" Foreground="#999999"/>
                                        <TextBlock Text="{Binding SelectedPoolRequest.RequestId, StringFormat='#{0}'}"
                                                   FontSize="13" FontWeight="Medium" Foreground="#E8182E"/>
                                        <TextBlock Text="{Binding SelectedPoolRequest.CustomerName}"
                                                   FontSize="12" Foreground="#555555"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Kategori" FontSize="12"
                                           Foreground="#555555" Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding Categories}"
                                          SelectedItem="{Binding SelectedPoolCategory}"
                                          PlaceholderText="Kategori seçin"
                                          HorizontalAlignment="Stretch"
                                          Height="38" FontSize="13"
                                          Margin="0,0,0,14">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:Category">
                                            <TextBlock Text="{Binding CategoryName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="Öncelik" FontSize="12"
                                           Foreground="#555555" Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding Priorities}"
                                          SelectedItem="{Binding SelectedPoolPriority}"
                                          PlaceholderText="Öncelik seçin"
                                          HorizontalAlignment="Stretch"
                                          Height="38" FontSize="13"
                                          Margin="0,0,0,14"/>

                                <Button Content="Kategori Güncelle"
                                        Command="{Binding UpdateCategoryCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Height="42" FontSize="13" FontWeight="Medium"
                                        Background="#E8182E" Foreground="White"
                                        CornerRadius="8" Margin="0,0,0,8"/>

                                <Button Content="Bekleyene Gönder"
                                        Command="{Binding ReturnToPendingCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Height="42" FontSize="13" FontWeight="Medium"
                                        Background="#555555" Foreground="White"
                                        CornerRadius="8"/>
                            </StackPanel>

                            <!-- HATA / BAŞARI MESAJLARI -->
                            <Border Background="#FEF2F2" BorderBrush="#FECACA"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="12,10" Margin="0,12,0,0"
                                    IsVisible="{Binding ErrorMessage,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="#B91C1C" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Border Background="#F0FDF4" BorderBrush="#BBF7D0"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="12,10" Margin="0,12,0,0"
                                    IsVisible="{Binding SuccessMessage,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding SuccessMessage}"
                                           Foreground="#15803D" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

            </Grid>
        </Grid>

    </DockPanel>
</Window>