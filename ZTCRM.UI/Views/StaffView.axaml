<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZTCRM.ViewModels"
        xmlns:models="using:ZTCRM.Models"
        x:Class="ZTCRM.UI.Views.StaffView"
        x:DataType="vm:StaffViewModel"
        Title="ZTCRM — Personel Paneli"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Background="#2C2C2C">

    <DockPanel>

        <!-- HEADER -->
        <Border DockPanel.Dock="Top" Background="#2C2C2C" Height="68">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center">
                    <Border Width="42" Height="42" CornerRadius="8" Background="#E8182E">
                        <PathIcon Width="22" Height="22" Foreground="White"
                                  Data="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-7 9h-2V5h2v6zm0 4h-2v-2h2v2z"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="ZTCRM" Foreground="White" FontSize="18"
                                   FontWeight="Medium" LetterSpacing="3"/>
                        <TextBlock Text="ŞİKAYET YÖNETİM SİSTEMİ"
                                   Foreground="#AAAAAA" FontSize="9" LetterSpacing="2"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{Binding WelcomeMessage}"
                               Foreground="#AAAAAA" FontSize="12"/>
                    <TextBlock Text="|" Foreground="#3A3A3A" FontSize="11"/>
                    <TextBlock Text="v1.0.0" Foreground="#444444" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Kırmızı çizgi -->
        <Border DockPanel.Dock="Top" Height="3" Background="#E8182E"/>
        <Border DockPanel.Dock="Top" Height="1" Background="#3A3A3A"/>

        <!-- FOOTER -->
        <Border DockPanel.Dock="Bottom" Background="#2C2C2C" Height="44"
                BorderThickness="0,1,0,0" BorderBrush="#3A3A3A">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
                <TextBlock Grid.Column="0" Text="Güvenli bağlantı aktif"
                           Foreground="#444444" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="© 2026 ZTCRM — Şikayet Yönetim Sistemi"
                           Foreground="#333333" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ORTA -->
        <Grid>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#C8102E" Offset="0"/>
                        <GradientStop Color="#8C0B1F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Canvas>
                <Ellipse Canvas.Left="700" Canvas.Top="-140"
                         Width="560" Height="560"
                         Fill="#A50E26" Opacity="0.5"/>
                <Ellipse Canvas.Left="-160" Canvas.Top="300"
                         Width="480" Height="480"
                         Fill="#A50E26" Opacity="0.4"/>
            </Canvas>

            <Grid ColumnDefinitions="*,580" Margin="32" RowDefinitions="*">

                <!-- SOL: Birim Havuzu -->
                <Border Grid.Column="0" Background="White" CornerRadius="12"
                        Padding="28,24" Margin="0,0,16,0">
                    <Border.BoxShadow>0 8 40 0 #40000000</Border.BoxShadow>
                    <DockPanel>

                        <Border DockPanel.Dock="Top"
                                BorderThickness="0,0,0,2" BorderBrush="#E8182E"
                                Padding="0,0,0,16" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#E8182E">
                                    <PathIcon Width="16" Height="16" Foreground="White"
                                              Data="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Birim Havuzu"
                                               FontSize="14" FontWeight="Medium"
                                               Foreground="#111111"/>
                                    <TextBlock Text="Atanmayı bekleyen başvurular"
                                               FontSize="11" Foreground="#999999"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Button DockPanel.Dock="Bottom"
                                Content="Üstüme Al"
                                Command="{Binding AssignToSelfCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="42" FontSize="13" FontWeight="Medium"
                                Background="#E8182E" Foreground="White"
                                CornerRadius="8" Margin="0,16,0,0"/>

                        <DataGrid ItemsSource="{Binding PoolRequests}"
                                  SelectedItem="{Binding SelectedPoolRequest}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="No"
                                                    Binding="{Binding RequestId}"
                                                    Width="55"/>
                                <DataGridTextColumn Header="Müşteri"
                                                    Binding="{Binding CustomerName}"
                                                    Width="130"/>
                                <DataGridTextColumn Header="Kategori"
                                                    Binding="{Binding CategoryName}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Öncelik"
                                                    Binding="{Binding Priority}"
                                                    Width="80"/>
                                <DataGridTextColumn Header="Açıklama"
                                                    Binding="{Binding Description}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Tarih"
                                                    Binding="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                                    Width="100"/>
                                <DataGridTemplateColumn Header="Detay" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="models:ServiceRequest">
                                            <Button Content="Gör"
                                                    Tag="{Binding}"
                                                    Click="DetailButton_Click"
                                                    HorizontalAlignment="Center"
                                                    Height="26" FontSize="11"
                                                    Background="#E8182E" Foreground="White"
                                                    CornerRadius="4" Padding="10,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                    </DockPanel>
                </Border>

                <!-- SAĞ: Üstümdekiler + İşlem Paneli -->
                <Grid Grid.Column="1" RowDefinitions="*,Auto">

                    <!-- SAĞ ÜST: Üstümdeki Başvurular -->
                    <Border Grid.Row="0" Background="White" CornerRadius="12"
                            Padding="28,24" Margin="0,0,0,16">
                        <Border.BoxShadow>0 8 40 0 #40000000</Border.BoxShadow>
                        <DockPanel>

                            <Border DockPanel.Dock="Top"
                                    BorderThickness="0,0,0,2" BorderBrush="#E8182E"
                                    Padding="0,0,0,16" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="36" Height="36" CornerRadius="8" Background="#E8182E">
                                        <PathIcon Width="16" Height="16" Foreground="White"
                                                  Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Üstümdeki Başvurular"
                                                   FontSize="14" FontWeight="Medium"
                                                   Foreground="#111111"/>
                                        <TextBlock Text="Üzerime aldığım başvurular"
                                                   FontSize="11" Foreground="#999999"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <DataGrid ItemsSource="{Binding MyRequests}"
                                      SelectedItem="{Binding SelectedMyRequest}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="No"
                                                        Binding="{Binding RequestId}"
                                                        Width="55"/>
                                    <DataGridTextColumn Header="Müşteri"
                                                        Binding="{Binding CustomerName}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="Kategori"
                                                        Binding="{Binding CategoryName}"
                                                        Width="130"/>
                                    <DataGridTextColumn Header="Öncelik"
                                                        Binding="{Binding Priority}"
                                                        Width="80"/>
                                    <DataGridTextColumn Header="Durum"
                                                        Binding="{Binding CurrentStatus}"
                                                        Width="120"/>
                                    <DataGridTemplateColumn Header="Detay" Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="models:ServiceRequest">
                                                <Button Content="Gör"
                                                        Tag="{Binding}"
                                                        Click="DetailButton_Click"
                                                        HorizontalAlignment="Center"
                                                        Height="26" FontSize="11"
                                                        Background="#E8182E" Foreground="White"
                                                        CornerRadius="4" Padding="10,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                        </DockPanel>
                    </Border>

                    <!-- SAĞ ALT: İşlem Paneli -->
                    <Border Grid.Row="1" Background="White" CornerRadius="12"
                            Padding="24,20">
                        <Border.BoxShadow>0 8 40 0 #40000000</Border.BoxShadow>
                        <StackPanel Spacing="0">

                            <TextBlock Text="İŞLEM PANELİ"
                                       FontSize="10" Foreground="#999999"
                                       LetterSpacing="1" Margin="0,0,0,12"/>

                            <Border Background="#F8F8F8" CornerRadius="8"
                                    Padding="14,10" Margin="0,0,0,14"
                                    IsVisible="{Binding SelectedMyRequest,
                                                Converter={x:Static ObjectConverters.IsNotNull}}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="SEÇİLİ BAŞVURU"
                                               FontSize="10" Foreground="#999999"/>
                                    <TextBlock Text="{Binding SelectedMyRequest.RequestId, StringFormat='#{0}'}"
                                               FontSize="13" FontWeight="Medium" Foreground="#E8182E"/>
                                    <TextBlock Text="{Binding SelectedMyRequest.CustomerName}"
                                               FontSize="12" Foreground="#555555"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Çözüm Notu" FontSize="12"
                                       Foreground="#555555" Margin="0,0,0,6"/>
                            <TextBox PlaceholderText="Çözüm açıklamasını yazın..."
                                     Text="{Binding ResolutionNote}"
                                     Height="70" FontSize="13"
                                     Background="#F8F8F8" Foreground="#111111"
                                     BorderBrush="#DDDDDD" BorderThickness="1"
                                     CornerRadius="6" Padding="10,8"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     Margin="0,0,0,12"/>

                            <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,12">
                                <Button Grid.Column="0" Content="Çözüldü"
                                        Command="{Binding ResolveCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Height="38" FontSize="12" FontWeight="Medium"
                                        Background="#16A34A" Foreground="White"
                                        CornerRadius="8" Margin="0,0,4,0"/>
                                <Button Grid.Column="1" Content="Çözülemez"
                                        Command="{Binding CannotResolveCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Height="38" FontSize="12" FontWeight="Medium"
                                        Background="#D97706" Foreground="White"
                                        CornerRadius="8" Margin="4,0,4,0"/>
                                <Button Grid.Column="2" Content="Havuza Gönder"
                                        Command="{Binding ReturnToPoolCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Height="38" FontSize="12" FontWeight="Medium"
                                        Background="#555555" Foreground="White"
                                        CornerRadius="8" Margin="4,0,0,0"/>
                            </Grid>

                            <Border Background="#FEF2F2" BorderBrush="#FECACA"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="12,10"
                                    IsVisible="{Binding ErrorMessage,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="#B91C1C" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Border Background="#F0FDF4" BorderBrush="#BBF7D0"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="12,10" Margin="0,8,0,0"
                                    IsVisible="{Binding SuccessMessage,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding SuccessMessage}"
                                           Foreground="#15803D" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>

                        </StackPanel>
                    </Border>

                </Grid>

            </Grid>
        </Grid>

    </DockPanel>
</Window>